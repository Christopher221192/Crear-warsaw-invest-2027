# --- DATABASE ---
# MotherDuck connection string (e.g. md:poland_listings?motherduck_token=...)
# Or just the token if the code handles the connection string construction.
MOTHERDUCK_TOKEN=your_motherduck_token_here

# --- AI & EXTERNAL APIS ---
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# --- ENVIRONMENT ---
ENVIRONMENT=production

# --- TELEGRAM & GITHUB BRIDGE ---
# Token given by BotFather on Telegram
TELEGRAM_BOT_TOKEN=ur_telegram_bot_token_here
# Your numerical private Telegram Chat ID (to prevent unauthorized triggers)
ALLOWED_CHAT_ID=ur_private_chat_id_here
# GitHub Classic or Fine-Grained Personal Access Token (PAT) with repo/action permissions
GITHUB_TOKEN=ur_github_pat_here
# GitHub organization/user and repository where the scraping Action will run
GITHUB_REPO_OWNER=ur_github_username
GITHUB_REPO_NAME=ProyectoPolandHouse
